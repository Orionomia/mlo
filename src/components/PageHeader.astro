---
import LogoBg from './LogoBg.astro';
interface BreadcrumbItem {
  label: string;
  href?: string;
}
interface Props {
  label: string;
  title: string;
  sub?: string;
  breadcrumbs?: BreadcrumbItem[];
  badge?: string;
}
const { label, title, sub, breadcrumbs, badge, print: showPrint } = Astro.props;

const schema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.label,
    ...(item.href ? { "item": `https://mlo.slupsk.pl${item.href}` } : {})
  }))
} : null;
---

<div class="page-header">
  <LogoBg />
  <div class="ph-inner">
    {breadcrumbs && (
      <nav aria-label="Ścieżka nawigacji" class="breadcrumbs">
        <ol class="bc-list">
          {breadcrumbs.map((item, i) => (
            <li class="bc-item">
              {i > 0 && <span class="bc-sep" aria-hidden="true">›</span>}
              {item.href
                ? <a href={item.href} class="bc-link">{item.label}</a>
                : <span class="bc-current" aria-current="page">{item.label}</span>
              }
            </li>
          ))}
        </ol>
      </nav>
    )}
    <div class="gold-line" style="margin-top:1.5rem;color:#E2A62D">{label}</div>
    <h1 class="display ph-title">{title}</h1>
    {sub && <p class="ph-sub">{sub}</p>}
  </div>
</div>

{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

<style>
  .page-header {
    background: linear-gradient(135deg, #01214F, #1a3570);
    position: relative; overflow: hidden;
    padding-top: var(--nav-h, 69px);
  }
  .page-header::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(226,166,45,.12) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .ph-inner {
    position: relative; max-width: 1400px; margin: 0 auto;
    padding: 3.5rem 2rem 3.5rem;
  }
  .ph-title {
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    font-weight: 800; color: #fff; line-height: .95; margin-bottom: .75rem;
  }
  .ph-sub {
    font-size: 1.05rem; color: rgba(255,255,255,.55);
    max-width: 560px; line-height: 1.75; margin-top: .75rem;
  }
  /* Breadcrumbs */
  .breadcrumbs { margin-bottom: 1.25rem; }
  .bc-list { list-style:none; padding:0; margin:0; display:flex; align-items:center; flex-wrap:wrap; gap:.25rem; }
  .bc-item { display:flex; align-items:center; gap:.25rem; }
  .bc-sep { color:rgba(255,255,255,.25); font-size:.8rem; }
  .bc-link { font-size:.75rem; color:rgba(255,255,255,.45); text-decoration:none; font-weight:500; transition:color .2s; }
  .bc-link:hover { color:#E2A62D; }
  .bc-current { font-size:.75rem; color:rgba(255,255,255,.8); font-weight:600; }
  @media (max-width: 768px) {
    .ph-inner { padding: 2.5rem 1.25rem 2.5rem; }
  }
.ph-badge{display:inline-block;background:rgba(226,166,45,.18);border:1px solid rgba(226,166,45,.35);color:#E2A62D;font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:.25rem .75rem;border-radius:100px;margin-top:.75rem}
</style>
