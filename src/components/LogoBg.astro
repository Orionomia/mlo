---
interface Props {
  opacity?: number;
  style?: string;
}
const { opacity = 0.06, style = '' } = Astro.props;
---
<img
  src="/logo-mlo.svg"
  alt=""
  aria-hidden="true"
  style={`position:absolute;right:-10%;top:-5%;height:110%;width:auto;pointer-events:none;user-select:none;opacity:${opacity};filter:brightness(5);z-index:0;${style}`}
/>
