---
import { NAV_LINKS } from '../data';

const currentPath = Astro.url.pathname;
---

<nav id="navbar">
  <!-- Main nav row -->
  <div class="nav-row">
    <div class="nav-inner">
      <!-- Logo -->
      <a href="/" class="nav-logo" aria-label="MLO Słupsk – strona główna">
        <img src="/logo-mlo.svg" alt="Logo MLO Słupsk" class="nav-logo-img" width="140" height="99" loading="eager" />
        <div class="logo-text">
          <span class="logo-name">MLO Słupsk</span>
          <span class="logo-sub">Młodzieżowe Liceum Ogólnokształcące w Słupsku</span>
        </div>
      </a>

      <!-- Desktop links -->
      <div class="nav-desktop" role="navigation" aria-label="Główna nawigacja">
        {NAV_LINKS.map(({ href, label }) => (
          <a
            href={href}
            class={`nav-link ${currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'active' : ''}`}
          >{label}</a>
        ))}
      </div>

      <!-- CTA -->
      <a href="/rekrutacja" class="nav-cta-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Aplikuj
      </a>

      <!-- Hamburger -->
      <button class="hamburger" id="hamburger" aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-drawer">
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</nav>

<!-- Overlay -->
<div id="drawer-overlay" class="drawer-overlay"></div>

<!-- Mobile drawer -->
<div id="mobile-drawer" class="mobile-drawer" role="dialog" aria-label="Menu mobilne" aria-modal="true">
  <button id="drawer-close" class="drawer-close" aria-label="Zamknij menu">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <div class="drawer-links">
    {NAV_LINKS.map(({ href, label }) => (
      <a
        href={href}
        class={`drawer-link ${currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'drawer-active' : ''}`}
      >
        {label}
        {(currentPath === href || (href !== '/' && currentPath.startsWith(href))) && (
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#E2A62D" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
        )}
      </a>
    ))}
  </div>

  <div class="drawer-footer">
    <a href="/rekrutacja" class="drawer-cta">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      Aplikuj 2025/2026
    </a>
    <div class="drawer-phones">
      <a href="tel:+48786933376" class="drawer-phone">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#E2A62D" stroke-width="2.5"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.25 1.01l-2.2 2.2z"/></svg>
        +48 786 933 376
      </a>
      <a href="tel:+48505525119" class="drawer-phone">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#E2A62D" stroke-width="2.5"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.25 1.01l-2.2 2.2z"/></svg>
        +48 505 525 119
      </a>
      <a href="mailto:liceum.nauka@wp.pl" class="drawer-phone">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#E2A62D" stroke-width="2.5"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/></svg>
        liceum.nauka@wp.pl
      </a>
    </div>
  </div>
</div>

<style>
  /* ── Nav wrapper ── */
  #navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 999;
    background: #01214F;
    border-bottom: 1px solid rgba(255,255,255,.08);
    transition: box-shadow .3s;
  }
  #navbar.scrolled {
    box-shadow: 0 4px 30px rgba(0,0,0,.3);
  }

  /* top strip removed - phone/email now only in mobile drawer footer */

  /* Main row */
  .nav-row { padding: 0 1.25rem; }
  .nav-inner {
    max-width: 1400px; margin: 0 auto;
    display: flex; align-items: center; height: 68px; gap: 1rem;
  }

  /* Logo */
  .nav-logo { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .nav-logo-img { height: 52px; width: auto; display: block; object-fit: contain; }
  .logo-text { text-align: left; line-height: 1.15; max-width: 200px; }
  .logo-name { display: block; font-weight: 700; font-size: 1rem; color: #fff; }
  .logo-sub  { display: block; font-size: .65rem; font-weight: 500; color: rgba(255,255,255,.45); letter-spacing: .03em; }

  /* Desktop links */
  .nav-desktop { flex: 1; display: flex; justify-content: center; gap: 0; flex-wrap: nowrap; overflow: hidden; }
  .nav-link {
    font-size: .86rem; font-weight: 500; color: rgba(255,255,255,.55);
    padding: .5rem .8rem; border-radius: 8px;
    border-bottom: 2px solid transparent;
    transition: all .18s;
  }
  .nav-link:hover { color: #fff; background: rgba(255,255,255,.08); }
  .nav-link.active { color: #fff; font-weight: 700; border-bottom-color: #E2A62D; }

  /* CTA */
  .nav-cta-btn {
    display: flex; align-items: center; gap: 6px;
    background: #E2A62D; color: #fff; border: none;
    padding: .6rem 1.4rem; border-radius: 8px;
    font-weight: 700; font-size: .86rem; flex-shrink: 0;
    box-shadow: 0 4px 14px #E2A62D44;
    transition: opacity .2s, transform .2s;
  }
  .nav-cta-btn:hover { opacity: .88; transform: translateY(-1px); }

  /* Hamburger */
  .hamburger {
    display: none; align-items: center; justify-content: center;
    background: none; border: 1.5px solid rgba(255,255,255,.25); border-radius: 9px;
    width: 40px; height: 40px; flex-shrink: 0;
    margin-left: auto; transition: border-color .2s;
  }
  .hamburger:hover { border-color: rgba(255,255,255,.6); }

  /* Overlay */
  .drawer-overlay {
    display: none; position: fixed; inset: 0; z-index: 997;
    background: rgba(1,33,79,.35); backdrop-filter: blur(3px);
  }
  .drawer-overlay.open { display: block; }

  /* Drawer */
  .mobile-drawer {
    position: fixed; top: 0; right: 0; bottom: 0; z-index: 998;
    width: 290px; background: #fff;
    box-shadow: -8px 0 40px rgba(1,33,79,.15);
    transform: translateX(100%);
    transition: transform .32s cubic-bezier(.16,1,.3,1);
    display: flex; flex-direction: column; overflow-y: auto;
  }
  .mobile-drawer.open { transform: translateX(0); }

  .drawer-close {
    position: absolute; top: .75rem; right: .75rem;
    background: rgba(255,255,255,.1); border: none; border-radius: 8px;
    width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;
    transition: background .2s; cursor: pointer;
  }
  .drawer-close:hover { background: rgba(255,255,255,.2); }

  .drawer-links { flex: 1; padding: 4rem 0 .5rem; }
  .drawer-link {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: .9rem 1.25rem;
    font-size: .9rem; font-weight: 500; color: #555;
    border-left: 3px solid transparent;
    transition: all .18s;
  }
  .drawer-link:hover { background: #f8f8f8; color: #01214F; }
  .drawer-active { background: #fff8ee; color: #01214F; font-weight: 700; border-left-color: #E2A62D; }

  .drawer-footer { padding: 1.1rem 1.25rem; border-top: 1.5px solid #f0f0f0; flex-shrink: 0; }
  .drawer-cta {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; background: #E2A62D; color: #fff;
    padding: .95rem; border-radius: 10px; font-weight: 700; font-size: .88rem;
    box-shadow: 0 4px 14px #E2A62D44; margin-bottom: .9rem;
    transition: opacity .2s;
  }
  .drawer-cta:hover { opacity: .85; }
  .drawer-phones { display: flex; flex-direction: column; gap: .4rem; }
  .drawer-phone { display: flex; align-items: center; gap: 8px; font-size: .82rem; color: #767676; font-weight: 500; }

  @media (max-width: 1024px) {
    .nav-desktop, .nav-cta-btn { display: none !important; }
    .hamburger { display: flex !important; }
  }
  @media (max-width: 768px) {
    .nav-subtitle { display: none; }
  }
</style>

<script>
  const navbar    = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger')!;
  const drawer    = document.getElementById('mobile-drawer')!;
  const overlay   = document.getElementById('drawer-overlay')!;
  const btnClose  = document.getElementById('drawer-close')!;
  const iconMenu  = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll shadow
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 24);
  });

  // Open drawer
  function openDrawer() {
    drawer.classList.add('open');
    overlay.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
    iconMenu.style.display  = 'none';
    iconClose.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  // Close drawer
  function closeDrawer() {
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    iconMenu.style.display  = 'block';
    iconClose.style.display = 'none';
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', () => {
    drawer.classList.contains('open') ? closeDrawer() : openDrawer();
  });
  btnClose.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  // Close on resize
  window.addEventListener('resize', () => {
    if (window.innerWidth > 1024) closeDrawer();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });
</script>
