---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import { PROFILES } from '../data';
const ICON_PATHS = {
  'ogolny': `<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>`,
  'humanistyczny': `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`,
  'psychologiczny': `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  'filmowo-aktorski': `<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>` ,
  'policyjny': `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  'wojskowy': `<circle cx="12" cy="8" r="6"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>`,
  'pozarniczy': `<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3z"/>`,
};
---
<Layout title="Profile klas" description="7 profili klas w MLO Słupsk — ogólny, humanistyczny, psychologiczny, filmowo-aktorski oraz klasy mundurowe: policyjna, wojskowa i pożarnicza." keywords="profile klas MLO Słupsk, klasa mundurowa Słupsk, klasa policyjna, klasa wojskowa, klasa pożarnicza, klasa ogólna liceum Słupsk, klasa humanistyczna, klasa psychologiczna, klasa filmowo-aktorska Słupsk">
  <Navbar />
  <main>
    <PageHeader
      breadcrumbs={[{'label':'Start','href':'/'},{'label':'Profile klas'}]} label="Profile klas" title="Siedem dróg do sukcesu" sub="Wybierz profil dopasowany do Twoich pasji i celów zawodowych." />
    <section class="sec">
      <div class="container">
        <div class="profiles-grid">
          {PROFILES.map((p) => (
            <a href={`/profile/${p.slug}`} class="profile-card hover-card" style={`--accent:${p.color};--pale:${p.pale}`}>
              <div class="pc-top">
                <div class="pc-head">
                  <div class="pc-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={p.color} stroke-width="2" set:html={ICON_PATHS[p.id] || ''}></svg></div>
                  <div class="pc-num">{p.num}</div>
                </div>
                {p.badge && <span class="pc-badge">Mundurowy</span>}
                <h3 class="display pc-title">{p.title}</h3>
                <div class="pc-sub">{p.sub}</div>
              </div>
              <div class="pc-body">
                <p class="pc-desc">{p.desc}</p>
                <div class="pc-more">Szczegóły →</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
<style>
.sec{background:#f8f8f8;padding:5rem 2rem}
.container{max-width:1400px;margin:0 auto}
.profiles-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem}
.profile-card{background:#fff;border:1.5px solid #ebebeb;border-radius:20px;overflow:hidden;display:flex;flex-direction:column;transition:all .28s cubic-bezier(.16,1,.3,1)}
.profile-card:hover{transform:translateY(-6px);box-shadow:0 20px 50px rgba(1,33,79,.1);border-color:var(--accent)}
.pc-top{background:var(--pale);padding:2rem 2rem 1.5rem;border-bottom:1.5px solid rgba(0,0,0,.05)}
.pc-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem}
.pc-icon{width:48px;height:48px;background:#fff;border-radius:12px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px rgba(0,0,0,.08)}
.pc-num{font-size:.62rem;font-weight:700;letter-spacing:.18em;color:rgba(0,0,0,.2);text-transform:uppercase}
.pc-badge{display:inline-block;background:#fff3e0;color:#01214F;border:1px solid #01214F33;border-radius:100px;font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.15rem .55rem;margin-bottom:.5rem}
.pc-title{font-size:1.5rem;font-weight:800;color:#01214F;margin-bottom:.3rem}
.pc-sub{font-size:.8rem;color:var(--accent);font-weight:600}
.pc-body{padding:1.5rem 2rem;flex:1;display:flex;flex-direction:column}
.pc-desc{font-size:.85rem;color:#767676;line-height:1.65;flex:1;margin-bottom:1.25rem}
.pc-more{font-size:.76rem;font-weight:700;color:#01214F}
@media(max-width:480px){.profiles-grid{grid-template-columns:1fr}.sec{padding:3.5rem 1.25rem}}
</style>
