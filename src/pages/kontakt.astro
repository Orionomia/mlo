---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
---
<Layout title="Kontakt" description="Kontakt z MLO Słupsk. Adres: ul. Wojska Polskiego 46A, Słupsk. Telefon: +48 786 933 376. Znajdź nas na mapie." keywords="kontakt MLO Słupsk, adres liceum Słupsk, telefon MLO, jak dojechać do MLO Słupsk">
  <Navbar />
  <main>
    <PageHeader
      breadcrumbs={[{'label':'Start','href':'/'},{'label':'Kontakt'}]} label="Kontakt" title="Porozmawiajmy" sub="Chętnie odpowiemy na wszystkie pytania — zadzwoń lub wpadnij do nas." />
    <section class="sec">
      <div class="container">
      <div class="r-grid">

        <!-- Dane kontaktowe -->
        <div>
          <div class="gold-line" style="margin-bottom:.75rem">Dane kontaktowe</div>
          <h2 class="display sec-h2">Gdzie nas szukać?</h2>

          <div class="contact-list">
            <div class="contact-item">
              <div class="ci-icon" style="background:#fef2f2">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div class="ci-lbl">Adres</div>
                <div class="ci-val">ul. Wojska Polskiego 46A<br/>76-200 Słupsk</div>
              </div>
            </div>
            <a href="tel:+48786933376" class="contact-item ci-link">
              <div class="ci-icon" style="background:#fff3e0">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#E2A62D" stroke-width="2.5"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.25 1.01l-2.2 2.2z"/></svg>
              </div>
              <div>
                <div class="ci-lbl">Telefon 1</div>
                <div class="ci-val ci-gold">+48 786 933 376</div>
              </div>
            </a>
            <a href="tel:+48505525119" class="contact-item ci-link">
              <div class="ci-icon" style="background:#fff3e0">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#E2A62D" stroke-width="2.5"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.25 1.01l-2.2 2.2z"/></svg>
              </div>
              <div>
                <div class="ci-lbl">Telefon 2</div>
                <div class="ci-val ci-gold">+48 505 525 119</div>
              </div>
            </a>
            <a href="mailto:liceum.nauka@wp.pl" class="contact-item ci-link">
              <div class="ci-icon" style="background:#f0fdf4">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/></svg>
              </div>
              <div>
                <div class="ci-lbl">E-mail</div>
                <div class="ci-val ci-green">liceum.nauka@wp.pl</div>
              </div>
            </a>
            <div class="contact-item">
              <div class="ci-icon" style="background:#eff6ff">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <div class="ci-lbl">Sekretariat</div>
                <div class="ci-val">Pn–Pt: 9:00–14:00</div>
              </div>
            </div>
            <a href="https://www.facebook.com/mlo.slupsk" target="_blank" rel="noopener" class="contact-item ci-link">
              <div class="ci-icon" style="background:#eff6ff">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </div>
              <div>
                <div class="ci-lbl">Facebook</div>
                <div class="ci-val">facebook.com/mlo.slupsk</div>
              </div>
            </a>

            <div class="contact-list-cta">
              <a href="tel:+48786933376" class="call-btn">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.25 1.01l-2.2 2.2z"/></svg>
                Zadzwoń teraz
              </a>
            </div>
          </div>

          <div class="access-box">
            <div class="access-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Dostępność dla osób niepełnosprawnych
            </div>
            <p>Szkoła jest przystosowana dla młodzieży niepełnosprawnej ruchowo:</p>
            <div class="access-items">
              <div class="access-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>wygodne podjazdy na parkingu przy wejściu</div>
              <div class="access-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>parking szkolny</div>
              <div class="access-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>winda</div>
              <div class="access-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>przystosowane toalety</div>
            </div>
          </div>
        </div>

        <!-- Mapa -->
        <div style="display:flex;flex-direction:column">
          <div class="gold-line" style="margin-bottom:.75rem">Jak do nas trafić?</div>
          <h2 class="display sec-h2">Znajdź nas na mapie</h2>
          <div class="map-wrap" id="map-container" style="flex:1">
            <iframe
              src="https://maps.google.com/maps?q=Młodzieżowe+Liceum+Ogólnokształcące+Słupsk+Wojska+Polskiego+46A&output=embed&hl=pl&z=17"
              width="100%" height="100%" style="border:0;display:block"
              allowfullscreen loading="lazy"
              title="Lokalizacja MLO Słupsk"
              id="map-iframe"
            ></iframe>
            <a href="https://www.google.com/maps/search/ul.+Wojska+Polskiego+46A,+76-200+S%C5%82upsk" target="_blank" rel="noopener noreferrer" class="map-placeholder" id="map-fallback" style="display:none">
              <div class="map-ph-inner">
                <div class="map-ph-pin">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div class="map-ph-addr">
                  <div class="map-ph-street">ul. Wojska Polskiego 46A</div>
                  <div class="map-ph-city">76-200 Słupsk</div>
                </div>
                <div class="map-ph-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Otwórz w Google Maps
                </div>
              </div>
            </a>
          </div>
        </div>

      </div>
      </div>
    </section>
  </main>
  <Footer />
<script>
  function checkMap() {
    const iframe = document.getElementById('map-iframe');
    const fallback = document.getElementById('map-fallback');
    if (!navigator.onLine) {
      iframe.style.display = 'none';
      fallback.style.display = 'flex';
    }
    window.addEventListener('offline', () => {
      iframe.style.display = 'none';
      fallback.style.display = 'flex';
    });
    window.addEventListener('online', () => {
      iframe.style.display = 'block';
      fallback.style.display = 'none';
    });
  }
  document.addEventListener('DOMContentLoaded', checkMap);
</script>
</Layout>
<style>
.sec{background:#f8f8f8;padding:5rem 2rem}
.container{max-width:1400px;margin:0 auto}
.r-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:5rem;align-items:stretch}
@media(max-width:768px){.r-grid{grid-template-columns:1fr;gap:2rem}}
.sec-h2{font-size:clamp(1.8rem,3vw,3rem);color:#01214F;font-weight:800;margin-bottom:2rem}
.contact-list{display:flex;flex-direction:column;gap:1px;border-radius:16px;border:1.5px solid #ebebeb;margin-bottom:1.75rem;overflow:hidden}
.contact-item{background:#fff;padding:1.25rem 1.5rem;display:flex;gap:1rem;align-items:center;border-bottom:1px solid #f5f5f5}
.ci-link{transition:background .2s;text-decoration:none;color:inherit}
.ci-link:hover{background:#fafafa}
.ci-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ci-lbl{font-size:.63rem;color:#767676;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.2rem}
.ci-val{font-size:.92rem;color:#01214F;font-weight:500}
.ci-gold{color:#01214F;font-weight:600}
.ci-blue{color:#2563eb;font-weight:600}
.cta-btn{display:flex;align-items:center;justify-content:center;gap:8px;background:#E2A62D;color:#fff;font-family:inherit;font-weight:700;font-size:.9rem;padding:1.1rem;border-radius:12px;box-shadow:0 4px 16px rgba(226,166,45,.4);transition:opacity .2s;border:none;width:100%;cursor:pointer;text-decoration:none}
.cta-btn:hover{opacity:.88}
.map-wrap{border-radius:16px;overflow:hidden;height:420px;border:1.5px solid #ebebeb;margin-bottom:1rem}
.map-embed{border-radius:16px;overflow:hidden;height:450px;border:1.5px solid #ebebeb;position:sticky;top:calc(var(--nav-h,69px) + 1rem)}
.map-embed iframe{display:block;width:100%;height:100%;border:0}
.map-wrap iframe{display:block;width:100%;height:100%}
.map-link{display:inline-flex;align-items:center;gap:7px;font-size:.82rem;font-weight:600;color:#01214F;border-bottom:1.5px solid #01214F;padding-bottom:1px;transition:color .2s}
.map-link:hover{color:#01214F;border-color:#01214F}
.access-box{background:#f0fdf4;border:1.5px solid #a7f3d0;border-radius:14px;padding:1.25rem 1.5rem;margin-bottom:1.25rem;margin-top:2rem}
.access-title{display:flex;align-items:center;gap:8px;font-weight:700;font-size:.88rem;color:#065f46;margin-bottom:.75rem}
.access-box p{font-size:.85rem;color:#444;margin-bottom:.75rem}
.access-items{display:flex;flex-direction:column;gap:.4rem}
.access-item{display:flex;align-items:center;gap:8px;font-size:.85rem;color:#444}
@media(max-width:768px){.r-grid{grid-template-columns:1fr;gap:3rem}.sec{padding:3.5rem 1.25rem}.map-wrap{height:300px}}
.map-links{display:flex;flex-direction:column;gap:1rem;margin-top:1rem}
.map-addr-link{font-size:1rem;font-weight:600;color:#01214F;text-decoration:underline;text-underline-offset:3px;transition:color .2s}
.map-addr-link:hover{color:#01214F}
.map-open-btn{display:inline-flex;align-items:center;gap:8px;background:#01214F;color:#fff;padding:.85rem 1.75rem;border-radius:10px;font-size:.88rem;font-weight:600;text-decoration:none;transition:background .2s;margin-top:.5rem}
.map-open-btn:hover{background:#E2A62D}
.call-btn:hover{opacity:.88}
.map-placeholder{display:block;border-radius:16px;overflow:hidden;height:520px;border:1.5px solid #ebebeb;margin-bottom:1rem;text-decoration:none;background:linear-gradient(135deg,#dbe4f0,#e8edf5);transition:box-shadow .2s}
.map-placeholder:hover{box-shadow:0 8px 32px rgba(1,33,79,.12)}
.map-ph-inner{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem}
.map-ph-pin{width:64px;height:64px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(1,33,79,.15)}
.map-ph-addr{text-align:center}
.map-ph-street{font-weight:700;font-size:1rem;color:#01214F;margin-bottom:.3rem}
.map-ph-city{font-size:.88rem;color:#666}
.map-ph-btn{display:flex;align-items:center;gap:6px;background:#01214F;color:#fff;padding:.7rem 1.5rem;border-radius:10px;font-size:.84rem;font-weight:600}
.contact-list-cta{padding:1rem 1.5rem 1.5rem;background:#fff;border-top:1px solid #f5f5f5}
.call-btn{display:flex;align-items:center;justify-content:center;gap:8px;background:#E2A62D;color:#fff;text-decoration:none;font-weight:700;font-size:.9rem;padding:1.1rem;border-radius:12px;box-shadow:0 4px 16px rgba(226,166,45,.3);transition:opacity .2s;width:100%}
.call-btn:hover{opacity:.88}
.map-wrap{border-radius:16px;overflow:hidden;height:100%;min-height:520px;border:1.5px solid #ebebeb;margin-bottom:1rem;position:relative}
</style>
