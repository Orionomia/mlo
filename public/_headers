# Cloudflare Pages — konfiguracja nagłówków HTTP
# Zastępuje public/.htaccess (Apache), które nie działa na Cloudflare Pages.
# Dokumentacja: https://developers.cloudflare.com/pages/configuration/headers/

# Nagłówki bezpieczeństwa — wszystkie odpowiedzi
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

# Długi cache dla statycznych assetów (obrazy, fonty, ikony, dokumenty)
/*.ico
  Cache-Control: public, max-age=31536000, immutable
/*.pdf
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.gif
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.ttf
  Cache-Control: public, max-age=31536000, immutable

# Uwaga: przekierowanie HTTP -> HTTPS nie jest tu potrzebne —
# Cloudflare Pages wymusza HTTPS automatycznie dla każdej domeny.
